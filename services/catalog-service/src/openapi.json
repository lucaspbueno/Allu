{
  "openapi": "3.0.3",
  "info": {
    "title": "Catalog Service API",
    "version": "0.3.0",
    "description": "Serviço de catálogo de produtos com Prisma + Postgres. Suporta listagem paginada (offset e cursor), filtros por categoria, busca por nome, faixa de preço, ordenação e cache em memória."
  },
  "servers": [{ "url": "http://localhost:3001", "description": "Local dev" }],
  "tags": [
    { "name": "Health", "description": "Verificação de saúde do serviço" },
    { "name": "Products", "description": "Operações sobre o catálogo de produtos" },
    { "name": "Categories", "description": "Categorias disponíveis no catálogo" }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "tags": ["Health"],
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Serviço operacional",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "service": { "type": "string", "example": "catalog-service" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/products": {
      "get": {
        "summary": "Listar produtos",
        "description": "Retorna produtos ativos com suporte a dois modos de paginação:\n\n- **Offset** (padrão): use `page` + `limit`. Retorna `total`, `totalPages`, `page`.\n- **Cursor**: passe `cursor` (ID do último item recebido). Retorna `nextCursor`, `hasMore`. Mais eficiente para grandes volumes.\n\nAmbos os modos aceitam os filtros `category`, `search`, `minPrice` e `maxPrice`.\nO modo offset também aceita `sortBy` e `order`.",
        "tags": ["Products"],
        "operationId": "listProducts",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Número da página — modo offset (ignorado quando `cursor` é informado)",
            "schema": { "type": "integer", "default": 1, "minimum": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Itens por página (1–100)",
            "schema": { "type": "integer", "default": 20, "minimum": 1, "maximum": 100 }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "ID do último item recebido — ativa o modo cursor. Use `nextCursor` da resposta anterior.",
            "schema": { "type": "integer" }
          },
          {
            "name": "category",
            "in": "query",
            "description": "Filtrar por categoria exata (ex.: Smartphones, Notebooks)",
            "schema": { "type": "string" }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Busca parcial por nome do produto (case-insensitive)",
            "schema": { "type": "string" }
          },
          {
            "name": "minPrice",
            "in": "query",
            "description": "Preço mínimo (inclusive)",
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "maxPrice",
            "in": "query",
            "description": "Preço máximo (inclusive)",
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "Campo de ordenação — apenas no modo offset",
            "schema": { "type": "string", "enum": ["name", "price", "createdAt"] }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Direção da ordenação — apenas no modo offset",
            "schema": { "type": "string", "enum": ["asc", "desc"], "default": "desc" }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de produtos (formato varia conforme o modo de paginação)",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/PaginatedProducts" },
                    { "$ref": "#/components/schemas/CursorPaginatedProducts" }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Parâmetro inválido (minPrice, maxPrice ou cursor não numérico)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "summary": "Obter produto por ID",
        "description": "Retorna os detalhes de um produto pelo ID numérico. Resultado cacheado em memória.",
        "tags": ["Products"],
        "operationId": "getProductById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID numérico do produto",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Produto encontrado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Product" }
              }
            }
          },
          "400": {
            "description": "ID inválido (não numérico)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Produto não encontrado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/products/categories": {
      "get": {
        "summary": "Listar categorias",
        "description": "Retorna todas as categorias distintas de produtos ativos, ordenadas alfabeticamente. Resultado cacheado em memória.",
        "tags": ["Categories"],
        "operationId": "listCategories",
        "responses": {
          "200": {
            "description": "Lista de categorias",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "type": "string" },
                      "example": ["Acessórios", "Notebooks", "Smartphones", "Tablets", "Wearables"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "iPhone 15 Pro" },
          "description": {
            "type": "string",
            "example": "Smartphone Apple com chip A17 Pro"
          },
          "price": { "type": "string", "format": "decimal", "example": "219.90" },
          "imageUrl": {
            "type": "string",
            "format": "uri",
            "example": "https://placehold.co/400x400?text=iPhone+15+Pro"
          },
          "category": { "type": "string", "example": "Smartphones" },
          "stock": { "type": "integer", "example": 50 },
          "active": { "type": "boolean", "example": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "PaginatedProducts": {
        "type": "object",
        "description": "Resposta do modo offset (page + limit)",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Product" }
          },
          "total": {
            "type": "integer",
            "description": "Total de produtos que satisfazem os filtros",
            "example": 10
          },
          "page": { "type": "integer", "example": 1 },
          "limit": { "type": "integer", "example": 20 },
          "totalPages": { "type": "integer", "example": 1 }
        }
      },
      "CursorPaginatedProducts": {
        "type": "object",
        "description": "Resposta do modo cursor",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Product" }
          },
          "nextCursor": {
            "type": "integer",
            "nullable": true,
            "description": "ID do último item — passe como `cursor` na próxima requisição. null indica última página.",
            "example": 15
          },
          "hasMore": { "type": "boolean", "example": true }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "Produto não encontrado" }
        }
      }
    }
  }
}
