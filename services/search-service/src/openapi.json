{
  "openapi": "3.0.3",
  "info": {
    "title": "Search Service API",
    "version": "0.1.0",
    "description": "Search and autocomplete service"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "service": { "type": "string", "example": "search-service" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
